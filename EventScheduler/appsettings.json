{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=EventSchedulerDb;Username=postgres;Password=admin"
  },
  "OpcUa": {
    "EndpointUrl": "opc.tcp://localhost:4840/UA/FactorySimulator",
    "TagMappings": {
      "ns=1;s=PumpSensor": "Signal.A",
      "ns=1;s=SetupSensor": "Signal.B",
      "ns=1;s=OperationComplete": "Signal.C"
    }
  },
  "InfluxDb": {
    "Url": "http://localhost:8086",
    "Token": "sms-cmms-dev-token",
    "Org": "sms-group",
    "Bucket": "factory-signals"
  }
}
